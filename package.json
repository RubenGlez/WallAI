  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules && rm -rf .expo && rm -rf ios && rm -rf android",
    "check": "npm run type-check && npm run lint",
    "catalog:fetch": "node scripts/fetch-catalog.cjs",
    "build:preview": "eas build --platform android --profile preview",
    "build:production": "eas build --platform android --profile production",
    "submit:production": "eas submit --platform android --profile production",
    "submit:internal": "eas submit --platform android --profile internal"
  },
